# ──────────────────────────────────────────────
# XTrader Signal Bridge — file da NON committare mai
# (token, dati personali, artefatti generati)
# ──────────────────────────────────────────────

# Configurazione reale e segreti
config.json
.env
*.secret

# CSV generati dal bridge
*.csv
segnali.csv
# ...ma il dizionario è un file dati versionato (non un CSV generato):
!data/dizionario_xtrader.csv

# Log e cache locali
logs/
*.log
__pycache__/
*.py[cod]
*$py.class

# Cartelle dati utente locali (history, backup)
history/
*.bak

# Dizionario Betfair locale (SQLite, issue #86): dati locali del PC, mai committati.
# Inclusi i file "sidecar" di SQLite (WAL/SHM/journal) che NON finiscono in *.db.
*.db
*.sqlite
*.sqlite3
*.db-*
*.sqlite-*
*.sqlite3-*
betfair_dictionary.db

# Parser Personalizzati definiti dall'utente (CP-01): salvati a runtime in
# data/parsers/<nome>.json. Sono configurazione utente, non vanno committati
# (lo skeleton di default è in codice, vedi xtrader_bridge/custom_parser.py).
data/parsers/

# Artefatti build / PyInstaller
build/
dist/
*.spec
*.exe
*.zip

# Ambienti virtuali
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
